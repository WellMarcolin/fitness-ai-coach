# === Intervals.icu ===
INTERVALS_ATHLETE_ID=i123456
INTERVALS_API_KEY=your_api_key_here

# === LLM Provider (choose one) ===
LLM_PROVIDER=deepseek   # deepseek | glm | groq | ollama | openrouter | opencode

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_MODEL=deepseek-chat

# GLM (Zhipu)
GLM_API_KEY=your_glm_key
GLM_MODEL=glm-4-flash

# Groq
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama3-70b-8192

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenRouter (acesso a DeepSeek, Claude, GPT e outros)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=deepseek/deepseek-chat

# OpenCode API
OPENCODE_API_KEY=your_opencode_key
OPENCODE_BASE_URL=https://api.opencode.ai/v1
OPENCODE_MODEL=deepseek-chat

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/fitness_coach.db

# === Server ===
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
